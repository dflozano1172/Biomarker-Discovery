# =============================================================================
# 5. SENSITIVITY A — Dichotomised WHO
# =============================================================================

run_lmm_dichot <- function(mk, data) {

  df_mk <- data |>
    filter(marker == mk) |>
    filter(!is.na(log_value), !is.na(who_dichot), !is.na(age),
           !is.na(sex), !is.na(bmi), !is.na(ethnicity),
           !is.na(imd), !is.na(n_comorbidities))

  fit <- tryCatch(
    lmer(log_value ~ time_bin * who_dichot +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 | subject_id),
         data = df_mk, REML = TRUE),
    error = function(e) { message("Dichot LMM failed for ", mk, ": ", e$message); NULL }
  )
  if (is.null(fit)) return(NULL)

  tidy_fit    <- tidy(fit, effects = "fixed", conf.int = TRUE, conf.level = 0.95)
  interaction <- tidy_fit |> filter(str_detect(term, "time_bin:who_dichot"))

  list(
    marker     = mk,
    int_beta   = interaction$estimate,
    int_se     = interaction$std.error,
    int_p      = interaction$p.value,
    int_ci_lo  = interaction$conf.low,
    int_ci_hi  = interaction$conf.high
  )
}

cat("\n=== Sensitivity A: Dichotomised WHO × Time ===\n")
lmm_dichot_results <- map(markers_list, run_lmm_dichot, data = df_raw)
names(lmm_dichot_results) <- markers_list

dichot_summary <- map_dfr(lmm_dichot_results, \(x) {
  if (is.null(x)) return(NULL)
  tibble(
    Marker        = x$marker,
    Beta_int      = round(x$int_beta, 4),
    SE            = round(x$int_se, 4),
    CI_lo         = round(x$int_ci_lo, 4),
    CI_hi         = round(x$int_ci_hi, 4),
    GMR_ratio     = round(exp(x$int_beta), 3),
    P_raw         = signif(x$int_p, 3)
  )
}) |>
  mutate(P_BH = round(p.adjust(P_raw, method = "BH"), 3)) |>
  arrange(P_raw)

print(kable(dichot_summary, format = "simple"))

