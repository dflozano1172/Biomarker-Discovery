print(kable(emm_tbl, format = "simple"))

# ---- [IMPROVEMENT 2] 4c. Pairwise WHO contrasts ----------------------------
cat("\n=== Pairwise WHO × Time Contrasts (diff-in-diff, BH corrected) ===\n")
pairwise_tbl <- map_dfr(lmm_cat_results, \(x) {
