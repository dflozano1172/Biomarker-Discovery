# =============================================================================
# OBJECTIVE 4: Change Over Time Stratified by Baseline WHO Severity (v2)
# Question:    Do marker trajectories differ by baseline WHO severity class?
#
# Primary:     LMM with Time × WHO interaction (categorical WHO)
#              — pre-specified reference: most common WHO category
#              — Type III F-test + LRT vs null model
#              — pairwise WHO contrasts (BH-corrected)
#              — partial η² effect size for interaction
#              — random slope model check (AIC)
# Secondary:   LMM with Time × WHO interaction (ordinal WHO — trend test)
# Sensitivity: (a) Dichotomised WHO (mild-moderate vs severe-critical)
#              (b) Exclude sparse extreme WHO categories
#              (c) Adjust for corticosteroid use (if available)
# Covariates:  Age, Sex, Ethnicity, IMD, BMI, N_comorbidities
#
# Improvements over v1:
#   [1] Pre-specified reference WHO category (most common)
#   [2] Pairwise WHO×Time contrasts with BH correction
#   [3] LRT: interaction model vs null (no-interaction) model
#   [4] Partial η² effect size for the interaction term
#   [5] Random slope model check (AIC comparison)
#   [6] Treatment confounding sensitivity (corticosteroid use)
#   [7] Observed means plot alongside predicted trajectories
#   [8] Clarified primary vs secondary model designation
# =============================================================================

# --- 0. Packages --------------------------------------------------------------
library(tidyverse)      # data wrangling + ggplot2
library(lme4)           # lmer()
library(lmerTest)       # Satterthwaite p-values
library(broom.mixed)    # tidy() for lmer objects
library(emmeans)        # marginal means & pairwise contrasts
library(effectsize)     # eta_squared()
library(car)            # vif()
library(influence.ME)   # Cook's distance for LMM
library(knitr)          # kable()
library(scales)         # log axis labels
library(patchwork)      # combine ggplots

# =============================================================================
# 1. DATA PREPARATION
# =============================================================================
# Expected long-format data, one row per subject × marker × timepoint:
#   subject_id        : unique patient identifier
#   timepoint         : factor "T1" / "T2"
#   time_bin          : numeric 0 (T1) / 1 (T2)
#   marker            : character — biomarker name
#   value             : numeric — raw marker value (no zeros expected)
#   log_value         : numeric — log(value)
#   who_cat           : factor — WHO severity class (e.g. 3,4,5,6,7)
