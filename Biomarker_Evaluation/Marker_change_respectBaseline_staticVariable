# =============================================================================
# [IMPROVEMENT 6] 7. SENSITIVITY C — Adjust for corticosteroid use
# =============================================================================

if (has_steroids) {
  cat("\n=== Sensitivity C: + Corticosteroid Use Adjustment ===\n")

  run_lmm_steroids <- function(mk, data) {
    df_mk <- data |>
      filter(marker == mk) |>
      filter(!is.na(log_value), !is.na(age), !is.na(sex), !is.na(bmi),
             !is.na(ethnicity), !is.na(imd), !is.na(n_comorbidities),
             !is.na(corticosteroid_use)) |>
      mutate(who_cat = relevel(droplevels(who_cat), ref = who_reference))

    fit <- tryCatch(
      lmer(log_value ~ time_bin * who_cat +
             age + sex + ethnicity + imd + bmi + n_comorbidities +
             corticosteroid_use +                  # treatment confounder
             (1 | subject_id),
           data = df_mk, REML = TRUE),
      error = function(e) { message("Steroid LMM failed for ", mk, ": ", e$message); NULL }
    )
    if (is.null(fit)) return(NULL)

    anova_fit <- anova(fit, type = "III")
    int_p     <- tryCatch(anova_fit["time_bin:who_cat", "Pr(>F)"],
                          error = function(e) NA_real_)

    list(marker = mk, interaction_p = int_p,
         n_used = nrow(df_mk), n_subjects = n_distinct(df_mk$subject_id))
  }

  lmm_steroid_results <- map(markers_list, run_lmm_steroids, data = df_raw)
  names(lmm_steroid_results) <- markers_list

  steroid_summary <- map_dfr(lmm_steroid_results, \(x) {
    if (is.null(x)) return(NULL)
    tibble(Marker = x$marker, N_subjects = x$n_subjects,
           Interaction_p = signif(x$interaction_p, 3))
  }) |>
    mutate(Interaction_p_BH = round(p.adjust(Interaction_p, method = "BH"), 3))

  print(kable(steroid_summary, format = "simple"))
  cat("  Interpretation: compare these p-values to primary model.\n",
      " If attenuation is large, corticosteroid use may partly explain\n",
      " the WHO × trajectory association.\n")
} else {
  cat("\n✗ Sensitivity C skipped — corticosteroid data not available.\n",
      "  Recommend collecting this variable; flag as limitation in paper.\n")
}

