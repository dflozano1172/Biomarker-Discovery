# =============================================================================
# 2. PRIMARY LMM — Categorical WHO × Time (PRIMARY model)
# =============================================================================

run_lmm_cat <- function(mk, data, ref_cat = who_reference) {

  df_mk <- data |>
    filter(marker == mk) |>
    filter(!is.na(log_value), !is.na(age), !is.na(sex), !is.na(bmi),
           !is.na(ethnicity), !is.na(imd), !is.na(n_comorbidities))

  # Apply pre-specified reference category
  df_mk <- df_mk |>
    mutate(who_cat = relevel(droplevels(who_cat), ref = ref_cat))

  # ---- 2a. Interaction model (primary) --------------------------------------
  fit_int <- tryCatch(
    lmer(log_value ~ time_bin * who_cat +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 | subject_id),
         data = df_mk, REML = TRUE),
    error = function(e) { message("Primary LMM failed for ", mk, ": ", e$message); NULL }
  )
  if (is.null(fit_int)) return(NULL)

  # ---- [IMPROVEMENT 3] LRT: interaction vs null (no-interaction) model ------
  # Refit both with REML = FALSE for valid LRT
  fit_int_ml <- tryCatch(
    update(fit_int, REML = FALSE),
    error = function(e) NULL
  )
  fit_null_ml <- tryCatch(
    lmer(log_value ~ time_bin + who_cat +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 | subject_id),
         data = df_mk, REML = FALSE),
    error = function(e) NULL
  )

  lrt_result <- if (!is.null(fit_int_ml) && !is.null(fit_null_ml)) {
    lrt <- anova(fit_null_ml, fit_int_ml)
    list(
      chi_sq = lrt$Chisq[2],
      df     = lrt$Df[2],
      p      = lrt$`Pr(>Chisq)`[2]
    )
  } else list(chi_sq = NA, df = NA, p = NA)

  # ---- 2b. Fixed effects from REML model ------------------------------------
  tidy_fit        <- tidy(fit_int, effects = "fixed", conf.int = TRUE,
                          conf.level = 0.95)
  interaction_rows <- tidy_fit |> filter(str_detect(term, "time_bin:who_cat"))

  # ---- 2c. Type III F-test for overall interaction --------------------------
  anova_fit       <- anova(fit_int, type = "III")
  interaction_f_p <- tryCatch(
    anova_fit["time_bin:who_cat", "Pr(>F)"],
    error = function(e) NA_real_
  )

  # ---- [IMPROVEMENT 4] Partial η² for interaction --------------------------
  eta2_int <- tryCatch(
    eta_squared(anova_fit, partial = TRUE) |>
      as.data.frame() |>
      filter(str_detect(Parameter, "time_bin:who_cat")) |>
      pull(Eta2_partial),
    error = function(e) NA_real_
  )

  # ---- 2d. emmeans: within-WHO GMR (T2 vs T1) -------------------------------
  emm <- tryCatch(
    emmeans(fit_int, ~ timepoint | who_cat,
            at = list(time_bin = c(0, 1)),
            pbkrtest.limit = 5000),
    error = function(e) NULL
  )

  emm_within <- if (!is.null(emm)) {
    contrast(emm, method = "revpairwise") |>
      as.data.frame() |>
      mutate(
        GMR    = round(exp(estimate), 3),
        GMR_lo = round(exp(estimate - 1.96 * SE), 3),
        GMR_hi = round(exp(estimate + 1.96 * SE), 3),
        p_adj  = round(p.adjust(p.value, method = "BH"), 3)
      )
  } else NULL

  # ---- [IMPROVEMENT 2] Pairwise WHO contrasts: difference-in-differences ----
  # Tests whether the T1→T2 change differs BETWEEN WHO categories
  emm_time_who <- tryCatch(
    emmeans(fit_int, ~ who_cat | timepoint,
            at = list(time_bin = c(0, 1)),
            pbkrtest.limit = 5000),
    error = function(e) NULL
  )

  pairwise_contrasts <- if (!is.null(emm_time_who)) {
    # Interaction contrasts: (T2-T1 in WHO_a) - (T2-T1 in WHO_b)
    contrast(emm_time_who, interaction = c("pairwise", "revpairwise")) |>
      as.data.frame() |>
      mutate(
        ratio_of_GMR = round(exp(estimate), 3),   # ratio of GMRs between WHO classes
        p_adj        = round(p.adjust(p.value, method = "BH"), 3)
      )
  } else NULL

  # ---- 2e. VIF check (main effects model) -----------------------------------
  fit_main <- tryCatch(
    lmer(log_value ~ time_bin + who_cat +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 | subject_id),
         data = df_mk, REML = TRUE),
    error = function(e) NULL
  )
  vif_vals <- if (!is.null(fit_main)) tryCatch(vif(fit_main), error = function(e) NULL)

  # ---- [IMPROVEMENT 5] Random slope model check (AIC) ----------------------
  fit_rs <- tryCatch(
    lmer(log_value ~ time_bin * who_cat +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 + time_bin | subject_id),
         data = df_mk, REML = TRUE,
         control = lmerControl(optimizer = "bobyqa")),
    error = function(e) NULL
  )

  rs_check <- if (!is.null(fit_rs)) {
    list(
      AIC_ri = AIC(fit_int),   # random intercept
      AIC_rs = AIC(fit_rs),    # random slope
      prefer = if (AIC(fit_rs) < AIC(fit_int) - 2) "random slope" else "random intercept"
    )
  } else list(AIC_ri = AIC(fit_int), AIC_rs = NA, prefer = "random intercept (slope failed)")

  # ---- 2f. Normality diagnostics --------------------------------------------
  resids   <- residuals(fit_int)
  ranefs   <- ranef(fit_int)$subject_id[[1]]
  sw_resid <- shapiro.test(resids)
  sw_ranef <- shapiro.test(ranefs)

  list(
    marker             = mk,
    fit_cat            = fit_int,
    tidy_cat           = tidy_fit,
    interaction_rows   = interaction_rows,
    interaction_f_p    = interaction_f_p,
    eta2_partial       = eta2_int,
    lrt                = lrt_result,
    emm_within         = emm_within,
    pairwise_contrasts = pairwise_contrasts,
    vif_vals           = vif_vals,
    rs_check           = rs_check,
    sw_resid           = sw_resid$p.value,
    sw_ranef           = sw_ranef$p.value,
    n_used             = nrow(df_mk),
    n_subjects         = n_distinct(df_mk$subject_id)
  )
}

cat("\n=== Fitting primary LMMs (categorical WHO × Time) ===\n")
lmm_cat_results <- map(markers_list, run_lmm_cat, data = df_raw)
names(lmm_cat_results) <- markers_list

# =============================================================================
# 3. SECONDARY LMM — Ordinal WHO × Time (trend test)
# =============================================================================

run_lmm_ord <- function(mk, data) {

  df_mk <- data |>
    filter(marker == mk) |>
    filter(!is.na(log_value), !is.na(age), !is.na(sex), !is.na(bmi),
           !is.na(ethnicity), !is.na(imd), !is.na(n_comorbidities))

  fit <- tryCatch(
    lmer(log_value ~ time_bin * who_ord +
           age + sex + ethnicity + imd + bmi + n_comorbidities +
           (1 | subject_id),
         data = df_mk, REML = TRUE),
    error = function(e) { message("Ordinal LMM failed for ", mk, ": ", e$message); NULL }
  )
  if (is.null(fit)) return(NULL)

  tidy_fit  <- tidy(fit, effects = "fixed", conf.int = TRUE, conf.level = 0.95)
  trend_row <- tidy_fit |> filter(term == "time_bin:who_ord")

  list(
    marker      = mk,
    fit_ord     = fit,
    tidy_ord    = tidy_fit,
    trend_beta  = trend_row$estimate,
    trend_se    = trend_row$std.error,
    trend_p     = trend_row$p.value,
    trend_ci_lo = trend_row$conf.low,
    trend_ci_hi = trend_row$conf.high
  )
}

cat("\n=== Fitting secondary LMMs (ordinal WHO trend) ===\n")
lmm_ord_results <- map(markers_list, run_lmm_ord, data = df_raw)
names(lmm_ord_results) <- markers_list

