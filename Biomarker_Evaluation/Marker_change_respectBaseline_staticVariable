# ---- [IMPROVEMENT 5] 4e. Random slope model check --------------------------
cat("\n=== Random Slope vs Random Intercept (AIC comparison) ===\n")
rs_tbl <- map_dfr(lmm_cat_results, \(x) {
  if (is.null(x)) return(NULL)
  tibble(
    Marker          = x$marker,
